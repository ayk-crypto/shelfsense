# ─── ShelfSense Web — Environment Variables ───────────────────────────────────
# Copy this file to .env.local for local development overrides.
# For production (Vercel), set these as environment variables in the dashboard.

# ── API Base URL ──────────────────────────────────────────────────────────────
# Development: leave as /api (Vite dev server proxies /api → localhost:3000)
# Production:  full URL of your Render API, e.g. https://shelfsense-api.onrender.com
#              Do NOT include a trailing slash. Do NOT include /api.
VITE_API_BASE_URL=/api

# ── App environment ───────────────────────────────────────────────────────────
# Set to "production" in Vercel to enable production-only behaviour.
VITE_APP_ENV=development
