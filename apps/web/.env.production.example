# ─── ShelfSense Web — Production Environment ─────────────────────────────────
# Set these as environment variables on your Vercel production deployment.
# Build-time variables — baked into the JS bundle at build time.

# Full URL of your Render production API service — no trailing slash, no /api suffix
VITE_API_BASE_URL=https://shelfsense-api.onrender.com

# App environment label
VITE_APP_ENV=production
