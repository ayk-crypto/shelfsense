# ─── ShelfSense Web — Development Environment ────────────────────────────────
# Copy this file to .env (or .env.development) for local development.
# Vite dev server proxies /api → localhost:3000 automatically.

# API base URL — leave as /api in dev (Vite proxy handles it)
VITE_API_BASE_URL=/api

# App environment label (used for UI warnings/indicators)
VITE_APP_ENV=development
