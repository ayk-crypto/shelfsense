# ─── ShelfSense Web — Staging Environment ────────────────────────────────────
# Set these as environment variables on your Vercel staging deployment.
# Build-time variables — baked into the JS bundle at build time.

# Full URL of your Render staging API service — no trailing slash, no /api suffix
VITE_API_BASE_URL=https://shelfsense-api-staging.onrender.com

# App environment label
VITE_APP_ENV=staging
