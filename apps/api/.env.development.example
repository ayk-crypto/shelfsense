# ─── ShelfSense API — Development Environment ────────────────────────────────
# Copy this file to .env (or .env.development) for local development.
# NEVER commit the real .env file.

NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Local PostgreSQL (default) — or point to your personal Neon dev branch.
# Dev databases may use localhost. Production connections from localhost are blocked.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shelfsense?schema=public

# ── Auth ──────────────────────────────────────────────────────────────────────
# Weak dev secret is fine locally — production enforces ≥32 chars.
JWT_SECRET=dev-secret-not-for-production

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000,http://127.0.0.1:5000

# ── Frontend URL ──────────────────────────────────────────────────────────────
WEB_BASE_URL=http://localhost:5000

# ── Email — disabled in dev (links logged to console) ─────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@shelfsense.local
EMAIL_FROM_NAME=ShelfSense Dev
