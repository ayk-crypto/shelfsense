# ─── ShelfSense API — Staging Environment ────────────────────────────────────
# Set these as environment variables on your Render staging service.
# Copy this file to .env.staging locally only if you need to run staging locally.
# NEVER commit the real .env.staging file with actual credentials.

NODE_ENV=staging
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Separate Neon project/branch for staging. MUST NOT be the production DB.
# Get this from: Neon dashboard → staging project → Connection Details → Pooled
DATABASE_URL=postgres://user:pass@ep-staging-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-secure-random-staging-secret-min-32-chars

# ── CORS ──────────────────────────────────────────────────────────────────────
# Your staging frontend URL (Vercel preview or dedicated staging domain)
CORS_ALLOWED_ORIGINS=https://shelfsense-staging.vercel.app

# ── Frontend URL ──────────────────────────────────────────────────────────────
WEB_BASE_URL=https://shelfsense-staging.vercel.app

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=staging@shelfsense.app
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=staging@shelfsense.app
EMAIL_FROM_NAME=ShelfSense (Staging)
