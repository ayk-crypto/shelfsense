# ─── ShelfSense API — Production Environment ─────────────────────────────────
# Set ALL of these as environment variables in your Render production service.
# DO NOT create a .env.production file locally with real production credentials.
# Production deployment reads env vars from Render, not from any .env file.

NODE_ENV=production
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Neon POOLED connection string for production.
# From: Neon dashboard → production project → Connection Details → Pooled
# IMPORTANT: Use the pooled connection string (with pgBouncer) for the API.
#            Use the DIRECT connection string only for running migrations.
DATABASE_URL=postgres://user:pass@ep-production-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Auth ──────────────────────────────────────────────────────────────────────
# REQUIRED — must be ≥32 chars. The server refuses to start without this.
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-production-secret-min-32-chars-keep-safe

# ── CORS ──────────────────────────────────────────────────────────────────────
# Production frontend URLs only. No localhost, no wildcards.
CORS_ALLOWED_ORIGINS=https://shelfsenseapp.com

# ── Frontend URL ──────────────────────────────────────────────────────────────
# Used in auth emails (password reset, verification links).
WEB_BASE_URL=https://shelfsenseapp.com

# ── Email ─────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=noreply@shelfsense.app
SMTP_PASS=replace-with-smtp-password
SMTP_FROM=noreply@shelfsenseapp.com
EMAIL_FROM_NAME=ShelfSense

# ── Support ───────────────────────────────────────────────────────────────────
SUPPORT_FROM=support@shelfsenseapp.com
SUPPORT_INBOUND_SECRET=replace-with-webhook-secret
