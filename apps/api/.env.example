# ─── ShelfSense API — Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in values for local development.
# For production (Render), set these as environment variables in the dashboard.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ──────────────────────────────────────────────────────────────────
# Development: local PostgreSQL
# Production: Neon pooled connection string (from Neon dashboard → Connection Details → Pooled)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/shelfsense?schema=public

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# REQUIRED in production — must be at least 32 characters
JWT_SECRET=replace-with-a-secure-random-secret-min-32-chars

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slashes).
# Development: localhost URLs
# Production: your Vercel domain, e.g. https://shelfsense.vercel.app
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000,http://127.0.0.1:5000

# ── Frontend URL ──────────────────────────────────────────────────────────────
# Used to build links inside auth emails (password reset, email verification).
# Development: http://localhost:5000
# Production: your Vercel frontend URL, e.g. https://shelfsense.vercel.app
WEB_BASE_URL=http://localhost:5000

# ── Email / SMTP ──────────────────────────────────────────────────────────────
# Optional in development — auth email links are logged to the console instead.
# Required in production for password reset and email verification.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# Sender address shown in emails (SMTP_FROM takes precedence over EMAIL_FROM)
SMTP_FROM=noreply@shelfsense.app
EMAIL_FROM_NAME=ShelfSense

# ── Payment Gateway ───────────────────────────────────────────────────────────
# Set PAYMENT_PROVIDER to "paddle" for Paddle Billing.
# Other values: "mock" (development), "payfast", "safepay" (legacy stubs)
PAYMENT_PROVIDER=mock

# ── Paddle Billing ────────────────────────────────────────────────────────────
# Required only when PAYMENT_PROVIDER=paddle
# PADDLE_ENV: "sandbox" (testing) or "production"
PADDLE_ENV=sandbox
# Server-side API key — NEVER expose to frontend
PADDLE_API_KEY=
# Webhook signing secret — from Paddle dashboard → Notifications → Webhook
PADDLE_WEBHOOK_SECRET=
# Price IDs from your Paddle product catalog
PADDLE_BASIC_MONTHLY_PRICE_ID=
PADDLE_BASIC_ANNUAL_PRICE_ID=
PADDLE_PRO_MONTHLY_PRICE_ID=
PADDLE_PRO_ANNUAL_PRICE_ID=
# Frontend base URL (used for Paddle success/cancel redirect URLs)
APP_FRONTEND_URL=http://localhost:5000
