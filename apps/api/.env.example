PORT=4000
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/shelfsense?schema=public"
JWT_SECRET="replace-with-a-secure-random-secret-min-32-chars"
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5000,http://127.0.0.1:5000

# Email / SMTP — optional in development (links are logged to console instead)
# Required in production for password reset and email verification emails
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@shelfsense.app
EMAIL_FROM_NAME=ShelfSense

# Public base URL used to build links inside auth emails
APP_URL=http://localhost:5000
