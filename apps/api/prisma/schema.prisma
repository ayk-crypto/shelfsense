generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  MANAGER
  OPERATOR
}

enum PlatformRole {
  USER
  SUPER_ADMIN
  SUPPORT_ADMIN
}

enum PlanTier {
  FREE
  BASIC
  PRO
}

enum StockMovementType {
  STOCK_IN
  STOCK_OUT
  WASTAGE
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
}

enum StockCountStatus {
  DRAFT
  FINALIZED
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  EXPIRED
  SUSPENDED
  CANCELLED
  MANUAL_REVIEW
}

enum BillingCycle {
  MONTHLY
  ANNUAL
  MANUAL
  CUSTOM
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum BillingCycleRestriction {
  ANY
  MONTHLY
  ANNUAL
}

enum CouponDurationType {
  ONCE
  REPEATING
  FOREVER
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD_MANUAL
  EASYPAISA
  JAZZCASH
  OTHER
  MOCK
  PAYFAST
  SAFEPAY
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum EmailLogStatus {
  QUEUED
  SENT
  FAILED
}

enum AnnouncementSeverity {
  INFO
  SUCCESS
  WARNING
  CRITICAL
}

enum AnnouncementTarget {
  ALL
  PLAN
  WORKSPACE
}

enum TicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketSource {
  EMAIL
  PORTAL
  ADMIN
}

enum MessageDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

model User {
  id                    String          @id @default(uuid()) @db.Uuid
  name                  String
  email                 String          @unique
  password              String
  emailVerified         Boolean         @default(false)
  isDisabled            Boolean         @default(false)
  platformRole          PlatformRole    @default(USER)
  passwordResetRequired Boolean         @default(false)
  failedLoginAttempts   Int             @default(0)
  lockedUntil           DateTime?
  lastLoginAt           DateTime?
  createdAt             DateTime        @default(now())
  ownedSpaces           Workspace[]     @relation("WorkspaceOwner")
  memberships           Membership[]
  auditLogs             AuditLog[]
  notifications         Notification[]
  createdStockCounts    StockCount[]    @relation("StockCountCreatedBy")
  finalizedStockCounts  StockCount[]    @relation("StockCountFinalizedBy")
  passwordResetTokens   PasswordResetToken[]
  emailVerifTokens      EmailVerifToken[]
  adminAuditLogs        AdminAuditLog[]
  recordedPayments      Payment[]
  updatedEmailTemplates EmailTemplate[]
  createdAnnouncements  Announcement[]
  supportTickets        SupportTicket[]       @relation("SupportTicketUser")
  assignedTickets       SupportTicket[]       @relation("SupportTicketAssignee")
  supportMessages       SupportMessage[]      @relation("SupportMessageCreatedBy")
  supportNotes          SupportInternalNote[] @relation("SupportNoteCreatedBy")
  supportEvents         SupportTicketEvent[]  @relation("SupportEventActor")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model EmailVerifToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model Workspace {
  id                             String      @id @default(uuid()) @db.Uuid
  name                           String
  currency                       String      @default("PKR")
  lowStockMultiplier             Float       @default(2)
  expiryAlertDays                Int         @default(7)
  ownerPhone                     String?
  notifyLowStock                 Boolean     @default(true)
  notifyExpiringSoon             Boolean     @default(true)
  notifyExpired                  Boolean     @default(true)
  whatsappAlertsEnabled          Boolean     @default(false)
  emailAlertsEnabled             Boolean     @default(false)
  pushAlertsEnabled              Boolean     @default(false)
  emailLowStock                  Boolean     @default(false)
  emailExpiringSoon              Boolean     @default(false)
  emailExpired                   Boolean     @default(false)
  dailyDigestEnabled             Boolean     @default(false)
  lastScheduledLowStockEmailAt   DateTime?
  lastScheduledExpirySoonEmailAt DateTime?
  lastDailyDigestSentAt          DateTime?
  onboardingCompleted            Boolean     @default(false)
  onboardingStep                 Int         @default(0)
  businessType                   String?
  plan                           PlanTier    @default(FREE)
  suspended                      Boolean     @default(false)
  suspendedAt                    DateTime?
  suspendReason                  String?
  trialEndsAt                    DateTime?
  subscriptionStatus             String?
  ownerId                        String      @db.Uuid
  createdAt                      DateTime    @default(now())
  owner                          User        @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships                    Membership[]
  locations                      Location[]
  items                          Item[]
  stockBatches                   StockBatch[]
  stockMovements                 StockMovement[]
  suppliers                      Supplier[]
  purchases                      Purchase[]
  auditLogs                      AuditLog[]
  notifications                  Notification[]
  customRoles                    CustomRole[]
  stockCounts                    StockCount[]
  subscriptions                  Subscription[]
  payments                       Payment[]
  invoices                       Invoice[]
  billingEvents                  BillingEvent[]
  supportTickets                 SupportTicket[]
}

model Notification {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  userId      String?   @db.Uuid
  type        String
  title       String
  message     String
  entity      String?
  entityId    String?
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([type])
  @@index([readAt])
  @@index([createdAt])
  @@index([workspaceId, type, entity, entityId, createdAt])
}

model AuditLog {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  userId      String    @db.Uuid
  action      String
  entity      String
  entityId    String
  meta        Json
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Location {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  workspaceId    String          @db.Uuid
  isActive       Boolean         @default(true)
  archivedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stockBatches   StockBatch[]
  stockMovements StockMovement[]
  purchases      Purchase[]
  stockCounts    StockCount[]

  @@index([workspaceId])
  @@index([workspaceId, isActive])
  @@unique([workspaceId, name])
}

model CustomRole {
  id          String       @id @default(uuid()) @db.Uuid
  workspaceId String       @db.Uuid
  name        String
  color       String       @default("#6366f1")
  baseRole    Role
  permissions Json         @default("[]")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  memberships Membership[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Membership {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid
  workspaceId   String      @db.Uuid
  role          Role
  customRoleId  String?     @db.Uuid
  isActive      Boolean     @default(true)
  deactivatedAt DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace     Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customRole    CustomRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@index([workspaceId, isActive])
}

model Item {
  id              String          @id @default(uuid()) @db.Uuid
  name            String
  sku             String?
  barcode         String?
  unit            String
  category        String?
  minStockLevel   Float           @default(0)
  trackExpiry     Boolean         @default(false)
  isActive        Boolean         @default(true)
  archivedAt      DateTime?
  workspaceId     String          @db.Uuid
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  workspace       Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stockBatches    StockBatch[]
  stockMovements  StockMovement[]
  purchaseItems   PurchaseItem[]
  stockCountItems StockCountItem[]

  @@index([workspaceId])
  @@index([workspaceId, isActive])
  @@unique([workspaceId, barcode])
}

model StockBatch {
  id                String          @id @default(uuid()) @db.Uuid
  itemId            String          @db.Uuid
  workspaceId       String          @db.Uuid
  locationId        String          @db.Uuid
  supplierId        String?         @db.Uuid
  quantity          Float
  remainingQuantity Float
  unitCost          Float?
  expiryDate        DateTime?
  batchNo           String?
  supplierName      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  item              Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)
  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  location          Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  supplier          Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  stockMovements    StockMovement[]

  @@index([workspaceId])
  @@index([locationId])
  @@index([itemId])
  @@index([supplierId])
  @@index([expiryDate])
}

model StockMovement {
  id          String            @id @default(uuid()) @db.Uuid
  workspaceId String            @db.Uuid
  locationId  String            @db.Uuid
  itemId      String            @db.Uuid
  batchId     String?           @db.Uuid
  type        StockMovementType
  quantity    Float
  unitCost    Float?
  reason      String?
  note        String?
  createdAt   DateTime          @default(now())
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  location    Location          @relation(fields: [locationId], references: [id], onDelete: Cascade)
  item        Item              @relation(fields: [itemId], references: [id], onDelete: Cascade)
  batch       StockBatch?       @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([locationId])
  @@index([itemId])
  @@index([batchId])
  @@index([type])
}

model StockCount {
  id            String           @id @default(uuid()) @db.Uuid
  workspaceId   String           @db.Uuid
  locationId    String           @db.Uuid
  createdById   String           @db.Uuid
  finalizedById String?          @db.Uuid
  status        StockCountStatus @default(DRAFT)
  note          String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  finalizedAt   DateTime?
  workspace     Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  location      Location         @relation(fields: [locationId], references: [id], onDelete: Restrict)
  createdBy     User             @relation("StockCountCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  finalizedBy   User?            @relation("StockCountFinalizedBy", fields: [finalizedById], references: [id], onDelete: Restrict)
  items         StockCountItem[]

  @@index([workspaceId])
  @@index([locationId])
  @@index([createdById])
  @@index([finalizedById])
  @@index([status])
  @@index([createdAt])
}

model StockCountItem {
  id               String     @id @default(uuid()) @db.Uuid
  stockCountId     String     @db.Uuid
  itemId           String     @db.Uuid
  itemName         String
  unit             String
  systemQuantity   Float
  physicalQuantity Float
  variance         Float
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  stockCount       StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  item             Item       @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@unique([stockCountId, itemId])
  @@index([stockCountId])
  @@index([itemId])
}

model Supplier {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  phone       String?
  notes       String?
  workspaceId String       @db.Uuid
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  purchases   Purchase[]
  stockBatches StockBatch[]

  @@index([workspaceId])
}

model Purchase {
  id                   String         @id @default(uuid()) @db.Uuid
  supplierId           String         @db.Uuid
  date                 DateTime
  orderedAt            DateTime?
  expectedDeliveryDate DateTime?
  receivedAt           DateTime?
  cancelledAt          DateTime?
  cancelReason         String?
  status               PurchaseStatus @default(DRAFT)
  totalAmount          Float
  workspaceId          String         @db.Uuid
  locationId           String         @db.Uuid
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  supplier             Supplier       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  workspace            Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  location             Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  purchaseItems        PurchaseItem[]

  @@index([workspaceId])
  @@index([locationId])
  @@index([supplierId])
  @@index([status])
  @@index([date])
  @@index([orderedAt])
}

model PurchaseItem {
  id               String    @id @default(uuid()) @db.Uuid
  purchaseId       String    @db.Uuid
  itemId           String    @db.Uuid
  quantity         Float
  receivedQuantity Float     @default(0)
  unitCost         Float
  total            Float
  expiryDate       DateTime?
  batchNo          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  purchase         Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  item             Item      @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
  @@index([itemId])
}

model AdminAuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  adminId   String   @db.Uuid
  action    String
  entity    String
  entityId  String
  meta      Json     @default("{}")
  createdAt DateTime @default(now())
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

// ── Platform admin models ─────────────────────────────────────────────

model Plan {
  id                        String    @id @default(uuid()) @db.Uuid
  name                      String
  code                      String    @unique
  description               String?
  monthlyPrice              Float     @default(0)
  annualPrice               Float     @default(0)
  currency                  String    @default("PKR")
  trialDays                 Int       @default(0)
  maxUsers                  Int?
  maxLocations              Int?
  maxItems                  Int?
  maxSuppliers              Int?
  maxPurchasesPerMonth      Int?
  maxStockMovementsPerMonth Int?
  enableExpiryTracking      Boolean   @default(true)
  enableBarcodeScanning     Boolean   @default(true)
  enableReports             Boolean   @default(true)
  enableAdvancedReports     Boolean   @default(false)
  enablePurchases           Boolean   @default(true)
  enableSuppliers           Boolean   @default(true)
  enableTeamManagement      Boolean   @default(true)
  enableCustomRoles         Boolean   @default(false)
  enableEmailAlerts         Boolean   @default(true)
  enableDailyOps            Boolean   @default(true)
  isPublic                  Boolean   @default(true)
  isActive                  Boolean   @default(true)
  sortOrder                 Int       @default(0)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  subscriptions             Subscription[]
  couponPlans               CouponPlan[]

  @@index([isActive])
  @@index([sortOrder])
}

model Subscription {
  id                      String             @id @default(uuid()) @db.Uuid
  workspaceId             String             @db.Uuid
  planId                  String             @db.Uuid
  status                  SubscriptionStatus @default(TRIAL)
  billingCycle            BillingCycle       @default(MANUAL)
  currency                String             @default("PKR")
  amount                  Float              @default(0)
  trialEndsAt             DateTime?
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  nextRenewalAt           DateTime?
  couponId                String?            @db.Uuid
  manualNotes             String?
  gatewayProvider         String?
  gatewayCustomerId       String?
  gatewaySubscriptionId   String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  workspace               Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan                    Plan               @relation(fields: [planId], references: [id])
  coupon                  Coupon?            @relation(fields: [couponId], references: [id], onDelete: SetNull)
  payments                Payment[]
  invoices                Invoice[]

  @@index([workspaceId])
  @@index([status])
  @@index([planId])
}

model Coupon {
  id                      String                  @id @default(uuid()) @db.Uuid
  code                    String                  @unique
  name                    String
  description             String?
  discountType            DiscountType
  discountValue           Float
  currency                String                  @default("PKR")
  validFrom               DateTime?
  validUntil              DateTime?
  maxRedemptions          Int?
  redemptionsUsed         Int                     @default(0)
  billingCycleRestriction BillingCycleRestriction @default(ANY)
  durationType            CouponDurationType      @default(ONCE)
  durationMonths          Int?
  isActive                Boolean                 @default(true)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  couponPlans             CouponPlan[]
  subscriptions           Subscription[]

  @@index([isActive])
  @@index([code])
}

model CouponPlan {
  couponId String @db.Uuid
  planId   String @db.Uuid
  coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  plan     Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@id([couponId, planId])
}

model Payment {
  id               String        @id @default(uuid()) @db.Uuid
  workspaceId      String        @db.Uuid
  subscriptionId   String?       @db.Uuid
  amount           Float
  currency         String        @default("PKR")
  paymentMethod    PaymentMethod @default(OTHER)
  referenceNumber  String?
  gatewayProvider  String?
  gatewayReference String?
  metadata         Json?
  status           PaymentStatus @default(PENDING)
  paidAt           DateTime?
  notes            String?
  recordedByUserId String        @db.Uuid
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  workspace        Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  recordedBy       User          @relation(fields: [recordedByUserId], references: [id])
  invoices         Invoice[]

  @@index([workspaceId])
  @@index([status])
  @@index([subscriptionId])
  @@index([createdAt])
}

model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  workspaceId    String        @db.Uuid
  subscriptionId String?       @db.Uuid
  paymentId      String?       @db.Uuid
  invoiceNumber  String        @unique
  amount         Float
  currency       String        @default("USD")
  status         InvoiceStatus @default(DRAFT)
  issuedAt       DateTime      @default(now())
  dueAt          DateTime?
  paidAt         DateTime?
  notes          String?
  lineItems      Json          @default("[]")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payment        Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([status])
  @@index([subscriptionId])
  @@index([createdAt])
}

model BillingEvent {
  id              String     @id @default(uuid()) @db.Uuid
  workspaceId     String?    @db.Uuid
  eventType       String
  gatewayProvider String?
  gatewayEventId  String?
  subscriptionId  String?    @db.Uuid
  paymentId       String?    @db.Uuid
  payload         Json?
  processedAt     DateTime   @default(now())
  createdAt       DateTime   @default(now())
  workspace       Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([gatewayProvider, gatewayEventId])
  @@index([workspaceId])
  @@index([eventType])
  @@index([createdAt])
}

model EmailTemplate {
  id              String    @id @default(uuid()) @db.Uuid
  key             String    @unique
  name            String
  subject         String
  htmlBody        String
  textBody        String
  enabled         Boolean   @default(true)
  variables       Json      @default("[]")
  updatedByUserId String?   @db.Uuid
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  updatedBy       User?     @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([key])
  @@index([enabled])
}

model EmailLog {
  id                String         @id @default(uuid()) @db.Uuid
  type              String
  recipient         String
  subject           String
  status            EmailLogStatus @default(SENT)
  provider          String?
  providerMessageId String?
  errorMessage      String?
  workspaceId       String?        @db.Uuid
  userId            String?        @db.Uuid
  createdAt         DateTime       @default(now())

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([workspaceId])
  @@index([recipient])
}

model Announcement {
  id                String               @id @default(uuid()) @db.Uuid
  title             String
  message           String
  severity          AnnouncementSeverity @default(INFO)
  targetType        AnnouncementTarget   @default(ALL)
  targetPlanId      String?              @db.Uuid
  targetWorkspaceId String?              @db.Uuid
  startsAt          DateTime?
  endsAt            DateTime?
  dismissible       Boolean              @default(true)
  isActive          Boolean              @default(true)
  createdByUserId   String               @db.Uuid
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  createdBy         User                 @relation(fields: [createdByUserId], references: [id])

  @@index([isActive])
  @@index([targetType])
  @@index([createdAt])
}

// ── Support Desk models ────────────────────────────────────────────────

model SupportTicket {
  id               String          @id @default(uuid()) @db.Uuid
  ticketNumber     Int             @unique @default(autoincrement())
  subject          String
  status           TicketStatus    @default(OPEN)
  priority         TicketPriority  @default(NORMAL)
  source           TicketSource    @default(EMAIL)
  category         String?
  workspaceId      String?         @db.Uuid
  userId           String?         @db.Uuid
  requesterEmail   String
  requesterName    String?
  assignedToUserId String?         @db.Uuid
  lastMessageAt    DateTime        @default(now())
  resolvedAt       DateTime?
  closedAt         DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  workspace        Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  user             User?           @relation("SupportTicketUser", fields: [userId], references: [id], onDelete: SetNull)
  assignedTo       User?           @relation("SupportTicketAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  messages         SupportMessage[]
  notes            SupportInternalNote[]
  events           SupportTicketEvent[]

  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([workspaceId])
  @@index([userId])
  @@index([assignedToUserId])
  @@index([lastMessageAt])
  @@index([createdAt])
}

model SupportMessage {
  id                String           @id @default(uuid()) @db.Uuid
  ticketId          String           @db.Uuid
  direction         MessageDirection
  senderEmail       String
  senderName        String?
  bodyHtml          String?
  bodyText          String
  providerMessageId String?
  attachments       Json?
  createdByUserId   String?          @db.Uuid
  createdAt         DateTime         @default(now())
  ticket            SupportTicket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdBy         User?            @relation("SupportMessageCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([direction])
  @@index([createdAt])
}

model SupportInternalNote {
  id              String        @id @default(uuid()) @db.Uuid
  ticketId        String        @db.Uuid
  note            String
  createdByUserId String        @db.Uuid
  createdAt       DateTime      @default(now())
  ticket          SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdBy       User          @relation("SupportNoteCreatedBy", fields: [createdByUserId], references: [id])

  @@index([ticketId])
  @@index([createdAt])
}

model SupportTicketEvent {
  id          String        @id @default(uuid()) @db.Uuid
  ticketId    String        @db.Uuid
  actorUserId String?       @db.Uuid
  eventType   String
  metadata    Json?
  createdAt   DateTime      @default(now())
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor       User?         @relation("SupportEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([createdAt])
}
