generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  MANAGER
  OPERATOR
}

enum PlatformRole {
  USER
  SUPER_ADMIN
  SUPPORT_ADMIN
}

enum PlanTier {
  FREE
  BASIC
  PRO
}

enum StockMovementType {
  STOCK_IN
  STOCK_OUT
  WASTAGE
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
}

enum StockCountStatus {
  DRAFT
  FINALIZED
  RETURNED
  REJECTED
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  EXPIRED
  SUSPENDED
  CANCELLED
  MANUAL_REVIEW
}

enum BillingCycle {
  MONTHLY
  ANNUAL
  MANUAL
  CUSTOM
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

enum BillingCycleRestriction {
  ANY
  MONTHLY
  ANNUAL
}

enum PlanPriceDisplayMode {
  FIXED
  CUSTOM
}

enum CouponDurationType {
  ONCE
  REPEATING
  FOREVER
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CARD_MANUAL
  EASYPAISA
  JAZZCASH
  OTHER
  MOCK
  PAYFAST
  SAFEPAY
  PADDLE
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  PAID
  VOID
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  CANCELLED
}

enum EmailLogStatus {
  QUEUED
  SENT
  FAILED
}

enum ItemSupplierRole {
  PRIMARY
  ALTERNATE
}

enum OcrStatus {
  NOT_UPLOADED
  UPLOADED
  PROCESSING
  EXTRACTED
  NEEDS_REVIEW
  FAILED
}

enum TaxMode {
  TAX_PER_UNIT
  TAX_PER_LINE
  ALLOCATED_FROM_INVOICE_TOTAL
  TAX_INCLUSIVE_PRICE
  NO_TAX
}

enum InvoiceLineMatchStatus {
  MATCHED
  NEEDS_REVIEW
  EXTRA_INVOICE_ITEM
  UNMATCHED
}

enum InventoryCostBasis {
  INCLUDING_TAX
  EXCLUDING_TAX
}

enum AnnouncementSeverity {
  INFO
  SUCCESS
  WARNING
  CRITICAL
}

enum AnnouncementTarget {
  ALL
  PLAN
  WORKSPACE
}

enum TicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum TicketSource {
  EMAIL
  PORTAL
  ADMIN
}

enum MessageDirection {
  INBOUND
  OUTBOUND
  INTERNAL
}

model User {
  id                    String          @id @default(uuid()) @db.Uuid
  name                  String
  email                 String          @unique
  password              String
  emailVerified         Boolean         @default(false)
  isDisabled            Boolean         @default(false)
  platformRole          PlatformRole    @default(USER)
  passwordResetRequired Boolean         @default(false)
  failedLoginAttempts   Int             @default(0)
  lockedUntil           DateTime?
  lastLoginAt           DateTime?
  createdAt             DateTime        @default(now())
  ownedSpaces           Workspace[]     @relation("WorkspaceOwner")
  extendedTrialSpaces   Workspace[]     @relation("WorkspaceTrialExtendedBy")
  archivedSpaces        Workspace[]     @relation("WorkspaceArchivedBy")
  deletedSpaces         Workspace[]     @relation("WorkspaceDeletedBy")
  lifecycleLogs         WorkspaceLifecycleLog[]
  memberships           Membership[]
  auditLogs             AuditLog[]
  notifications         Notification[]
  createdStockCounts    StockCount[]    @relation("StockCountCreatedBy")
  finalizedStockCounts  StockCount[]    @relation("StockCountFinalizedBy")
  returnedStockCounts   StockCount[]    @relation("StockCountReturnedBy")
  rejectedStockCounts   StockCount[]    @relation("StockCountRejectedBy")
  passwordResetTokens   PasswordResetToken[]
  emailVerifTokens      EmailVerifToken[]
  adminAuditLogs        AdminAuditLog[]
  recordedPayments      Payment[]
  updatedEmailTemplates EmailTemplate[]
  createdAnnouncements  Announcement[]
  supportTickets        SupportTicket[]       @relation("SupportTicketUser")
  assignedTickets       SupportTicket[]       @relation("SupportTicketAssignee")
  supportMessages       SupportMessage[]      @relation("SupportMessageCreatedBy")
  supportNotes          SupportInternalNote[] @relation("SupportNoteCreatedBy")
  supportEvents         SupportTicketEvent[]  @relation("SupportEventActor")
  invoiceUploads        SupplierInvoiceUpload[]
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model EmailVerifToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model Workspace {
  id                             String      @id @default(uuid()) @db.Uuid
  name                           String
  currency                       String      @default("PKR")
  lowStockMultiplier             Float       @default(2)
  expiryAlertDays                Int         @default(7)
  ownerPhone                     String?
  notifyLowStock                 Boolean     @default(true)
  notifyExpiringSoon             Boolean     @default(true)
  notifyExpired                  Boolean     @default(true)
  whatsappAlertsEnabled          Boolean     @default(false)
  emailAlertsEnabled             Boolean     @default(false)
  pushAlertsEnabled              Boolean     @default(false)
  emailLowStock                  Boolean     @default(false)
  emailExpiringSoon              Boolean     @default(false)
  emailExpired                   Boolean     @default(false)
  dailyDigestEnabled             Boolean     @default(false)
  lastScheduledLowStockEmailAt   DateTime?
  lastScheduledExpirySoonEmailAt DateTime?
  lastDailyDigestSentAt          DateTime?
  onboardingCompleted            Boolean     @default(false)
  onboardingStep                 Int         @default(0)
  businessType                   String?
  customUnits                    String[]    @default([])
  customCategories               String[]    @default([])
  customPurchaseUnits            String[]    @default([])
  plan                           PlanTier    @default(FREE)
  suspended                      Boolean     @default(false)
  suspendedAt                    DateTime?
  suspendReason                  String?
  trialEndsAt                    DateTime?
  trialStartedAt                 DateTime?
  trialExtendedAt                DateTime?
  trialExtendedByAdminId         String?     @db.Uuid
  trialExtensionReason           String?
  isDemoWorkspace                Boolean     @default(false)
  demoResetAt                    DateTime?
  archivedAt                     DateTime?
  archivedByAdminId              String?     @db.Uuid
  deletedAt                      DateTime?
  deletedByAdminId               String?     @db.Uuid
  deletionScheduledAt            DateTime?
  deletionReason                 String?
  subscriptionStatus             String?
  ownerId                        String      @db.Uuid
  createdAt                      DateTime    @default(now())
  owner                          User        @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  trialExtendedBy                User?       @relation("WorkspaceTrialExtendedBy", fields: [trialExtendedByAdminId], references: [id], onDelete: SetNull)
  archivedBy                     User?       @relation("WorkspaceArchivedBy", fields: [archivedByAdminId], references: [id], onDelete: SetNull)
  deletedBy                      User?       @relation("WorkspaceDeletedBy", fields: [deletedByAdminId], references: [id], onDelete: SetNull)
  memberships                    Membership[]
  locations                      Location[]
  items                          Item[]
  stockBatches                   StockBatch[]
  stockMovements                 StockMovement[]
  suppliers                      Supplier[]
  purchases                      Purchase[]
  itemSuppliers                  ItemSupplier[]
  auditLogs                      AuditLog[]
  notifications                  Notification[]
  customRoles                    CustomRole[]
  stockCounts                    StockCount[]
  subscriptions                  Subscription[]
  payments                       Payment[]
  invoices                       Invoice[]
  billingEvents                  BillingEvent[]
  supportTickets                 SupportTicket[]
  lifecycleLogs                  WorkspaceLifecycleLog[]
  inventoryCostBasis             InventoryCostBasis    @default(INCLUDING_TAX)
  invoiceUploads                 SupplierInvoiceUpload[]
  supplierItemAliases            SupplierItemAlias[]
  physicalCountSettings          PhysicalCountSettings?

  @@index([isDemoWorkspace])
  @@index([archivedAt])
  @@index([deletedAt])
  @@index([trialEndsAt])
}

model Notification {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  userId      String?   @db.Uuid
  type        String
  title       String
  message     String
  entity      String?
  entityId    String?
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([type])
  @@index([readAt])
  @@index([createdAt])
  @@index([workspaceId, type, entity, entityId, createdAt])
}

model AuditLog {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  userId      String    @db.Uuid
  action      String
  entity      String
  entityId    String
  meta        Json
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Location {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  workspaceId    String          @db.Uuid
  isActive       Boolean         @default(true)
  archivedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stockBatches   StockBatch[]
  stockMovements StockMovement[]
  purchases      Purchase[]
  stockCounts    StockCount[]

  @@index([workspaceId])
  @@index([workspaceId, isActive])
  @@unique([workspaceId, name])
}

model CustomRole {
  id          String       @id @default(uuid()) @db.Uuid
  workspaceId String       @db.Uuid
  name        String
  color       String       @default("#6366f1")
  baseRole    Role
  permissions Json         @default("[]")
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  memberships Membership[]

  @@unique([workspaceId, name])
  @@index([workspaceId])
}

model Membership {
  id            String      @id @default(uuid()) @db.Uuid
  userId        String      @db.Uuid
  workspaceId   String      @db.Uuid
  role          Role
  customRoleId  String?     @db.Uuid
  isActive      Boolean     @default(true)
  deactivatedAt DateTime?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace     Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  customRole    CustomRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
  @@index([workspaceId, isActive])
}

model Item {
  id                       String          @id @default(uuid()) @db.Uuid
  name                     String
  sku                      String?
  barcode                  String?
  unit                     String
  category                 String?
  minStockLevel            Float           @default(0)
  trackExpiry              Boolean         @default(false)
  isActive                 Boolean         @default(true)
  archivedAt               DateTime?
  workspaceId              String          @db.Uuid
  createdAt                DateTime        @default(now())
  updatedAt                DateTime        @updatedAt
  purchaseUnit             String?
  purchaseConversionFactor Float?
  issueUnit                String?
  displayBothUnits         Boolean         @default(false)
  workspace                Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stockBatches             StockBatch[]
  stockMovements           StockMovement[]
  purchaseItems            PurchaseItem[]
  stockCountItems          StockCountItem[]
  itemSuppliers            ItemSupplier[]
  supplierItemAliases      SupplierItemAlias[]

  @@index([workspaceId])
  @@index([workspaceId, isActive])
  @@unique([workspaceId, barcode])
}

model StockBatch {
  id                String          @id @default(uuid()) @db.Uuid
  itemId            String          @db.Uuid
  workspaceId       String          @db.Uuid
  locationId        String          @db.Uuid
  supplierId        String?         @db.Uuid
  quantity          Float
  remainingQuantity Float
  unitCost          Float?
  unitCostExclTax   Float?
  unitTax           Float?
  unitCostInclTax   Float?
  expiryDate        DateTime?
  batchNo           String?
  supplierName      String?
  receivedQuantity  Float?
  receivedUnit      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  item              Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)
  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  location          Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  supplier          Supplier?       @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  stockMovements    StockMovement[]

  @@index([workspaceId])
  @@index([locationId])
  @@index([itemId])
  @@index([supplierId])
  @@index([expiryDate])
}

model StockMovement {
  id               String            @id @default(uuid()) @db.Uuid
  workspaceId      String            @db.Uuid
  locationId       String            @db.Uuid
  itemId           String            @db.Uuid
  batchId          String?           @db.Uuid
  type             StockMovementType
  quantity         Float
  unitCost         Float?
  reason           String?
  note             String?
  enteredQuantity  Float?
  enteredUnit      String?
  conversionFactor Float?
  createdAt        DateTime          @default(now())
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  location    Location          @relation(fields: [locationId], references: [id], onDelete: Cascade)
  item        Item              @relation(fields: [itemId], references: [id], onDelete: Cascade)
  batch       StockBatch?       @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([locationId])
  @@index([itemId])
  @@index([batchId])
  @@index([type])
}

model StockCount {
  id              String           @id @default(uuid()) @db.Uuid
  workspaceId     String           @db.Uuid
  locationId      String           @db.Uuid
  createdById     String           @db.Uuid
  finalizedById   String?          @db.Uuid
  returnedById    String?          @db.Uuid
  rejectedById    String?          @db.Uuid
  status          StockCountStatus @default(DRAFT)
  note            String?
  managerComment  String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  finalizedAt     DateTime?
  returnedAt      DateTime?
  rejectedAt      DateTime?
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  location        Location         @relation(fields: [locationId], references: [id], onDelete: Restrict)
  createdBy       User             @relation("StockCountCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  finalizedBy     User?            @relation("StockCountFinalizedBy", fields: [finalizedById], references: [id], onDelete: Restrict)
  returnedBy      User?            @relation("StockCountReturnedBy", fields: [returnedById], references: [id], onDelete: Restrict)
  rejectedBy      User?            @relation("StockCountRejectedBy", fields: [rejectedById], references: [id], onDelete: Restrict)
  items           StockCountItem[]

  @@index([workspaceId])
  @@index([locationId])
  @@index([createdById])
  @@index([finalizedById])
  @@index([status])
  @@index([createdAt])
}

model StockCountItem {
  id               String     @id @default(uuid()) @db.Uuid
  stockCountId     String     @db.Uuid
  itemId           String     @db.Uuid
  itemName         String
  unit             String
  systemQuantity   Float
  physicalQuantity Float
  variance         Float
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt
  stockCount       StockCount @relation(fields: [stockCountId], references: [id], onDelete: Cascade)
  item             Item       @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@unique([stockCountId, itemId])
  @@index([stockCountId])
  @@index([itemId])
}

model Supplier {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  phone       String?
  notes       String?
  workspaceId String       @db.Uuid
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  purchases   Purchase[]
  stockBatches        StockBatch[]
  itemSuppliers       ItemSupplier[]
  supplierItemAliases SupplierItemAlias[]

  @@index([workspaceId])
}

model Purchase {
  id                   String         @id @default(uuid()) @db.Uuid
  supplierId           String         @db.Uuid
  date                 DateTime
  orderedAt            DateTime?
  expectedDeliveryDate DateTime?
  receivedAt           DateTime?
  cancelledAt          DateTime?
  cancelReason         String?
  status               PurchaseStatus @default(DRAFT)
  totalAmount          Float
  workspaceId          String         @db.Uuid
  locationId           String         @db.Uuid
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  supplier             Supplier       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  workspace            Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  location             Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  purchaseItems        PurchaseItem[]
  invoiceUploads       SupplierInvoiceUpload[]

  @@index([workspaceId])
  @@index([locationId])
  @@index([supplierId])
  @@index([status])
  @@index([date])
  @@index([orderedAt])
}

model PurchaseItem {
  id               String    @id @default(uuid()) @db.Uuid
  purchaseId       String    @db.Uuid
  itemId           String    @db.Uuid
  quantity         Float
  receivedQuantity Float     @default(0)
  unitCost         Float
  total            Float
  expiryDate       DateTime?
  batchNo          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  purchase         Purchase  @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  item             Item      @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
  @@index([itemId])
}

model ItemSupplier {
  id                    String           @id @default(uuid()) @db.Uuid
  workspaceId           String           @db.Uuid
  itemId                String           @db.Uuid
  supplierId            String           @db.Uuid
  role                  ItemSupplierRole @default(PRIMARY)
  supplierItemCode      String?
  preferredPurchaseUnit String?
  lastPurchasePrice     Float?
  lastPurchaseDate      DateTime?
  minimumOrderQuantity  Float?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  workspace             Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  item                  Item             @relation(fields: [itemId], references: [id], onDelete: Cascade)
  supplier              Supplier         @relation(fields: [supplierId], references: [id], onDelete: Cascade)

  @@unique([itemId, supplierId, role])
  @@index([workspaceId])
  @@index([itemId])
  @@index([supplierId])
  @@index([workspaceId, role])
}

model AdminAuditLog {
  id        String   @id @default(uuid()) @db.Uuid
  adminId   String   @db.Uuid
  action    String
  entity    String
  entityId  String
  meta      Json     @default("{}")
  createdAt DateTime @default(now())
  admin     User     @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

// ── Platform admin models ─────────────────────────────────────────────

model Plan {
  id                        String    @id @default(uuid()) @db.Uuid
  name                      String
  code                      String    @unique
  description               String?
  monthlyPrice              Float     @default(0)
  annualPrice               Float     @default(0)
  currency                  String    @default("USD")
  trialDays                 Int       @default(0)
  maxUsers                  Int?
  maxLocations              Int?
  maxItems                  Int?
  maxSuppliers              Int?
  maxPurchasesPerMonth      Int?
  maxStockMovementsPerMonth Int?
  enableExpiryTracking      Boolean   @default(true)
  enableBarcodeScanning     Boolean   @default(true)
  enableReports             Boolean   @default(true)
  enableAdvancedReports     Boolean   @default(false)
  enablePurchases           Boolean   @default(true)
  enableSuppliers           Boolean   @default(true)
  enableTeamManagement      Boolean   @default(true)
  enableCustomRoles         Boolean   @default(false)
  enableEmailAlerts         Boolean   @default(true)
  enableDailyOps            Boolean   @default(true)
  ctaText                   String?
  priceDisplayMode          PlanPriceDisplayMode @default(FIXED)
  isPublic                  Boolean   @default(true)
  isActive                  Boolean   @default(true)
  sortOrder                 Int       @default(0)
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  subscriptions             Subscription[]
  couponPlans               CouponPlan[]

  @@index([isActive])
  @@index([sortOrder])
}

model Subscription {
  id                      String             @id @default(uuid()) @db.Uuid
  workspaceId             String             @db.Uuid
  planId                  String             @db.Uuid
  status                  SubscriptionStatus @default(TRIAL)
  billingCycle            BillingCycle       @default(MANUAL)
  currency                String             @default("USD")
  amount                  Float              @default(0)
  trialEndsAt             DateTime?
  currentPeriodStart      DateTime?
  currentPeriodEnd        DateTime?
  nextRenewalAt           DateTime?
  couponId                String?            @db.Uuid
  manualNotes             String?
  gatewayProvider         String?
  gatewayCustomerId       String?
  gatewaySubscriptionId   String?
  gatewayTransactionId    String?
  gatewayPriceId          String?
  gatewayStatus           String?
  cancelAtPeriodEnd       Boolean            @default(false)
  lastPaymentAt           DateTime?
  nextBillingAt           DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  workspace               Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan                    Plan               @relation(fields: [planId], references: [id])
  coupon                  Coupon?            @relation(fields: [couponId], references: [id], onDelete: SetNull)
  payments                Payment[]
  invoices                Invoice[]

  @@index([workspaceId])
  @@index([status])
  @@index([planId])
}

model Coupon {
  id                      String                  @id @default(uuid()) @db.Uuid
  code                    String                  @unique
  name                    String
  description             String?
  discountType            DiscountType
  discountValue           Float
  currency                String                  @default("PKR")
  validFrom               DateTime?
  validUntil              DateTime?
  maxRedemptions          Int?
  redemptionsUsed         Int                     @default(0)
  billingCycleRestriction BillingCycleRestriction @default(ANY)
  durationType            CouponDurationType      @default(ONCE)
  durationMonths          Int?
  isActive                Boolean                 @default(true)
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  couponPlans             CouponPlan[]
  subscriptions           Subscription[]

  @@index([isActive])
  @@index([code])
}

model CouponPlan {
  couponId String @db.Uuid
  planId   String @db.Uuid
  coupon   Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  plan     Plan   @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@id([couponId, planId])
}

model Payment {
  id               String        @id @default(uuid()) @db.Uuid
  workspaceId      String        @db.Uuid
  subscriptionId   String?       @db.Uuid
  amount           Float
  currency         String        @default("USD")
  paymentMethod    PaymentMethod @default(OTHER)
  referenceNumber  String?
  gatewayProvider  String?
  gatewayReference String?
  metadata         Json?
  status           PaymentStatus @default(PENDING)
  paidAt           DateTime?
  notes            String?
  recordedByUserId String        @db.Uuid
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  workspace        Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subscription     Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  recordedBy       User          @relation(fields: [recordedByUserId], references: [id])
  invoices         Invoice[]

  @@index([workspaceId])
  @@index([status])
  @@index([subscriptionId])
  @@index([createdAt])
}

model Invoice {
  id             String        @id @default(uuid()) @db.Uuid
  workspaceId    String        @db.Uuid
  subscriptionId String?       @db.Uuid
  paymentId      String?       @db.Uuid
  invoiceNumber  String        @unique
  amount         Float
  currency       String        @default("USD")
  status         InvoiceStatus @default(DRAFT)
  issuedAt       DateTime      @default(now())
  dueAt          DateTime?
  paidAt         DateTime?
  notes          String?
  lineItems      Json          @default("[]")
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  workspace      Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  subscription   Subscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  payment        Payment?      @relation(fields: [paymentId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([status])
  @@index([subscriptionId])
  @@index([createdAt])
}

model BillingEvent {
  id              String     @id @default(uuid()) @db.Uuid
  workspaceId     String?    @db.Uuid
  eventType       String
  gatewayProvider String?
  gatewayEventId  String?
  subscriptionId  String?    @db.Uuid
  paymentId       String?    @db.Uuid
  payload         Json?
  processedAt     DateTime   @default(now())
  createdAt       DateTime   @default(now())
  workspace       Workspace? @relation(fields: [workspaceId], references: [id], onDelete: SetNull)

  @@unique([gatewayProvider, gatewayEventId])
  @@index([workspaceId])
  @@index([eventType])
  @@index([createdAt])
}

model WebhookEvent {
  id               String    @id @default(uuid()) @db.Uuid
  provider         String
  eventId          String    @unique
  eventType        String
  processingStatus String    @default("RECEIVED")
  rawPayload       Json
  processedAt      DateTime?
  errorMessage     String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([provider])
  @@index([processingStatus])
  @@index([createdAt])
}

model EmailTemplate {
  id              String    @id @default(uuid()) @db.Uuid
  key             String    @unique
  name            String
  subject         String
  htmlBody        String
  textBody        String
  enabled         Boolean   @default(true)
  variables       Json      @default("[]")
  updatedByUserId String?   @db.Uuid
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  updatedBy       User?     @relation(fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([key])
  @@index([enabled])
}

model EmailLog {
  id                String         @id @default(uuid()) @db.Uuid
  type              String
  recipient         String
  subject           String
  status            EmailLogStatus @default(SENT)
  provider          String?
  providerMessageId String?
  errorMessage      String?
  workspaceId       String?        @db.Uuid
  userId            String?        @db.Uuid
  createdAt         DateTime       @default(now())

  @@index([type])
  @@index([status])
  @@index([createdAt])
  @@index([workspaceId])
  @@index([recipient])
}

model Announcement {
  id                String               @id @default(uuid()) @db.Uuid
  title             String
  message           String
  severity          AnnouncementSeverity @default(INFO)
  targetType        AnnouncementTarget   @default(ALL)
  targetPlanId      String?              @db.Uuid
  targetWorkspaceId String?              @db.Uuid
  startsAt          DateTime?
  endsAt            DateTime?
  dismissible       Boolean              @default(true)
  isActive          Boolean              @default(true)
  createdByUserId   String               @db.Uuid
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  createdBy         User                 @relation(fields: [createdByUserId], references: [id])

  @@index([isActive])
  @@index([targetType])
  @@index([createdAt])
}

// ── Support Desk models ────────────────────────────────────────────────

model SupportTicket {
  id               String          @id @default(uuid()) @db.Uuid
  ticketNumber     Int             @unique @default(autoincrement())
  subject          String
  status           TicketStatus    @default(OPEN)
  priority         TicketPriority  @default(NORMAL)
  source           TicketSource    @default(EMAIL)
  category         String?
  workspaceId      String?         @db.Uuid
  userId           String?         @db.Uuid
  requesterEmail   String
  requesterName    String?
  assignedToUserId String?         @db.Uuid
  lastMessageAt    DateTime        @default(now())
  resolvedAt       DateTime?
  closedAt         DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  workspace        Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: SetNull)
  user             User?           @relation("SupportTicketUser", fields: [userId], references: [id], onDelete: SetNull)
  assignedTo       User?           @relation("SupportTicketAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)
  messages         SupportMessage[]
  notes            SupportInternalNote[]
  events           SupportTicketEvent[]

  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([workspaceId])
  @@index([userId])
  @@index([assignedToUserId])
  @@index([lastMessageAt])
  @@index([createdAt])
}

model SupportMessage {
  id                String           @id @default(uuid()) @db.Uuid
  ticketId          String           @db.Uuid
  direction         MessageDirection
  senderEmail       String
  senderName        String?
  bodyHtml          String?
  bodyText          String
  providerMessageId String?
  attachments       Json?
  createdByUserId   String?          @db.Uuid
  createdAt         DateTime         @default(now())
  ticket            SupportTicket    @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdBy         User?            @relation("SupportMessageCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([direction])
  @@index([createdAt])
}

model SupportInternalNote {
  id              String        @id @default(uuid()) @db.Uuid
  ticketId        String        @db.Uuid
  note            String
  createdByUserId String        @db.Uuid
  createdAt       DateTime      @default(now())
  ticket          SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdBy       User          @relation("SupportNoteCreatedBy", fields: [createdByUserId], references: [id])

  @@index([ticketId])
  @@index([createdAt])
}

model SupportTicketEvent {
  id          String        @id @default(uuid()) @db.Uuid
  ticketId    String        @db.Uuid
  actorUserId String?       @db.Uuid
  eventType   String
  metadata    Json?
  createdAt   DateTime      @default(now())
  ticket      SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  actor       User?         @relation("SupportEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([ticketId])
  @@index([createdAt])
}

model WorkspaceLifecycleLog {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  adminId     String    @db.Uuid
  action      String
  note        String?
  meta        Json?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  admin       User      @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([adminId])
  @@index([createdAt])
}

model SupplierInvoiceUpload {
  id                     String      @id @default(uuid()) @db.Uuid
  workspaceId            String      @db.Uuid
  purchaseOrderId        String?     @db.Uuid
  supplierId             String?     @db.Uuid
  uploadedById           String      @db.Uuid
  fileName               String
  fileType               String
  fileSize               Int
  filePath               String
  ocrStatus              OcrStatus   @default(UPLOADED)
  extractedRawText       String?
  extractedJson          Json?
  invoiceNumber          String?
  invoiceDate            DateTime?
  supplierName           String?
  invoiceSubtotalExclTax Float?
  invoiceTaxTotal        Float?
  invoiceTotalInclTax    Float?
  taxMode                TaxMode?
  duplicateWarning       Boolean     @default(false)
  createdAt              DateTime    @default(now())
  updatedAt              DateTime    @updatedAt
  workspace              Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  purchase               Purchase?   @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)
  uploadedBy             User        @relation(fields: [uploadedById], references: [id], onDelete: Restrict)
  invoiceLines           SupplierInvoiceLine[]

  @@index([workspaceId])
  @@index([purchaseOrderId])
  @@index([invoiceNumber])
}

model SupplierInvoiceLine {
  id                          String                 @id @default(uuid()) @db.Uuid
  invoiceUploadId             String                 @db.Uuid
  lineNumber                  Int
  rawDescription              String
  normalizedDescription       String?
  extractedQty                Float?
  extractedUnitCostExclTax    Float?
  extractedUnitTax            Float?
  extractedUnitCostInclTax    Float?
  extractedLineSubtotalExclTax Float?
  extractedLineTaxTotal       Float?
  extractedLineTotalInclTax   Float?
  extractedTaxRate            Float?
  extractedBatchNo            String?
  extractedExpiryDate         DateTime?
  taxMode                     TaxMode?
  suggestedInventoryItemId    String?                @db.Uuid
  matchedPurchaseItemId       String?                @db.Uuid
  confidenceScore             Float?
  matchStatus                 InvoiceLineMatchStatus?
  userConfirmedItemId         String?                @db.Uuid
  userConfirmedPurchaseItemId String?                @db.Uuid
  userEditedQty               Float?
  userEditedUnitCostExclTax   Float?
  userEditedUnitTax           Float?
  userEditedUnitCostInclTax   Float?
  userEditedBatchNo           String?
  userEditedExpiryDate        DateTime?
  userAction                  String?
  createdAt                   DateTime               @default(now())
  updatedAt                   DateTime               @updatedAt
  invoiceUpload               SupplierInvoiceUpload  @relation(fields: [invoiceUploadId], references: [id], onDelete: Cascade)

  @@index([invoiceUploadId])
}

model SupplierItemAlias {
  id                        String    @id @default(uuid()) @db.Uuid
  workspaceId               String    @db.Uuid
  supplierId                String?   @db.Uuid
  invoiceItemName           String
  normalizedInvoiceItemName String
  inventoryItemId           String    @db.Uuid
  confidenceBoost           Float     @default(0.2)
  lastConfirmedAt           DateTime?
  confirmedById             String?   @db.Uuid
  createdAt                 DateTime  @default(now())
  updatedAt                 DateTime  @updatedAt
  workspace                 Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  item                      Item      @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  supplier                  Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, supplierId, normalizedInvoiceItemName])
  @@index([workspaceId])
  @@index([workspaceId, supplierId])
}

model PhysicalCountSettings {
  id                   String    @id @default(uuid()) @db.Uuid
  workspaceId          String    @unique @db.Uuid
  locationId           String?   @db.Uuid
  enabled              Boolean   @default(true)
  frequencyType        String    @default("monthly")
  customIntervalNumber Int?
  customIntervalUnit   String?
  reminderLeadDays     Int       @default(0)
  lastCompletedAt      DateTime?
  lastCompletedCountId String?   @db.Uuid
  nextDueAt            DateTime?
  lastReminderSentAt   DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  workspace            Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([nextDueAt])
}
