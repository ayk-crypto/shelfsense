generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  MANAGER
  STAFF
}

enum StockMovementType {
  STOCK_IN
  STOCK_OUT
  WASTAGE
  ADJUSTMENT
}

model User {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  email       String       @unique
  password    String
  createdAt   DateTime     @default(now())
  ownedSpaces Workspace[]  @relation("WorkspaceOwner")
  memberships Membership[]
}

model Workspace {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  ownerId     String       @db.Uuid
  createdAt   DateTime     @default(now())
  owner       User         @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships Membership[]
  items       Item[]
  stockBatches StockBatch[]
  stockMovements StockMovement[]
}

model Membership {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  workspaceId String    @db.Uuid
  role        Role
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model Item {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  sku            String?
  barcode        String?
  unit           String
  category       String?
  minStockLevel  Float           @default(0)
  trackExpiry    Boolean         @default(false)
  workspaceId    String          @db.Uuid
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stockBatches   StockBatch[]
  stockMovements StockMovement[]

  @@index([workspaceId])
  @@unique([workspaceId, barcode])
}

model StockBatch {
  id                String          @id @default(uuid()) @db.Uuid
  itemId            String          @db.Uuid
  workspaceId       String          @db.Uuid
  quantity          Float
  remainingQuantity Float
  unitCost          Float?
  expiryDate        DateTime?
  batchNo           String?
  supplierName      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  item              Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)
  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stockMovements    StockMovement[]

  @@index([workspaceId])
  @@index([itemId])
  @@index([expiryDate])
}

model StockMovement {
  id          String            @id @default(uuid()) @db.Uuid
  workspaceId String            @db.Uuid
  itemId      String            @db.Uuid
  batchId     String?           @db.Uuid
  type        StockMovementType
  quantity    Float
  unitCost    Float?
  reason      String?
  note        String?
  createdAt   DateTime          @default(now())
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  item        Item              @relation(fields: [itemId], references: [id], onDelete: Cascade)
  batch       StockBatch?       @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([itemId])
  @@index([batchId])
  @@index([type])
}
