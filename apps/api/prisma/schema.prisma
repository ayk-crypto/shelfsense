generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  MANAGER
  OPERATOR
}

enum StockMovementType {
  STOCK_IN
  STOCK_OUT
  WASTAGE
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
}

model User {
  id          String       @id @default(uuid()) @db.Uuid
  name        String
  email       String       @unique
  password    String
  createdAt   DateTime     @default(now())
  ownedSpaces Workspace[]  @relation("WorkspaceOwner")
  memberships Membership[]
  auditLogs   AuditLog[]
  notifications Notification[]
}

model Workspace {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  currency       String          @default("PKR")
  lowStockMultiplier Float       @default(2)
  expiryAlertDays Int            @default(7)
  ownerPhone     String?
  notifyLowStock Boolean         @default(true)
  notifyExpiringSoon Boolean     @default(true)
  notifyExpired  Boolean         @default(true)
  whatsappAlertsEnabled Boolean  @default(false)
  emailAlertsEnabled Boolean     @default(false)
  pushAlertsEnabled Boolean      @default(false)
  onboardingCompleted Boolean    @default(false)
  ownerId        String          @db.Uuid
  createdAt      DateTime        @default(now())
  owner          User            @relation("WorkspaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  memberships    Membership[]
  locations      Location[]
  items          Item[]
  stockBatches StockBatch[]
  stockMovements StockMovement[]
  suppliers      Supplier[]
  purchases      Purchase[]
  auditLogs      AuditLog[]
  notifications  Notification[]
}

model Notification {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  userId      String?   @db.Uuid
  type        String
  title       String
  message     String
  entity      String?
  entityId    String?
  readAt      DateTime?
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([type])
  @@index([readAt])
  @@index([createdAt])
  @@index([workspaceId, type, entity, entityId, createdAt])
}

model AuditLog {
  id          String    @id @default(uuid()) @db.Uuid
  workspaceId String    @db.Uuid
  userId      String    @db.Uuid
  action      String
  entity      String
  entityId    String
  meta        Json
  createdAt   DateTime  @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Location {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  workspaceId    String          @db.Uuid
  createdAt      DateTime        @default(now())
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stockBatches   StockBatch[]
  stockMovements StockMovement[]
  purchases      Purchase[]

  @@index([workspaceId])
  @@unique([workspaceId, name])
}

model Membership {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @db.Uuid
  workspaceId String    @db.Uuid
  role        Role
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

model Item {
  id             String          @id @default(uuid()) @db.Uuid
  name           String
  sku            String?
  barcode        String?
  unit           String
  category       String?
  minStockLevel  Float           @default(0)
  trackExpiry    Boolean         @default(false)
  workspaceId    String          @db.Uuid
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stockBatches   StockBatch[]
  stockMovements StockMovement[]
  purchaseItems  PurchaseItem[]

  @@index([workspaceId])
  @@unique([workspaceId, barcode])
}

model StockBatch {
  id                String          @id @default(uuid()) @db.Uuid
  itemId            String          @db.Uuid
  workspaceId       String          @db.Uuid
  locationId        String          @db.Uuid
  quantity          Float
  remainingQuantity Float
  unitCost          Float?
  expiryDate        DateTime?
  batchNo           String?
  supplierName      String?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  item              Item            @relation(fields: [itemId], references: [id], onDelete: Cascade)
  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  location          Location        @relation(fields: [locationId], references: [id], onDelete: Cascade)
  stockMovements    StockMovement[]

  @@index([workspaceId])
  @@index([locationId])
  @@index([itemId])
  @@index([expiryDate])
}

model StockMovement {
  id          String            @id @default(uuid()) @db.Uuid
  workspaceId String            @db.Uuid
  locationId  String            @db.Uuid
  itemId      String            @db.Uuid
  batchId     String?           @db.Uuid
  type        StockMovementType
  quantity    Float
  unitCost    Float?
  reason      String?
  note        String?
  createdAt   DateTime          @default(now())
  workspace   Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  location    Location          @relation(fields: [locationId], references: [id], onDelete: Cascade)
  item        Item              @relation(fields: [itemId], references: [id], onDelete: Cascade)
  batch       StockBatch?       @relation(fields: [batchId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
  @@index([locationId])
  @@index([itemId])
  @@index([batchId])
  @@index([type])
}

model Supplier {
  id          String     @id @default(uuid()) @db.Uuid
  name        String
  phone       String?
  notes       String?
  workspaceId String     @db.Uuid
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  purchases   Purchase[]

  @@index([workspaceId])
}

model Purchase {
  id            String         @id @default(uuid()) @db.Uuid
  supplierId    String         @db.Uuid
  date          DateTime
  totalAmount   Float
  workspaceId   String         @db.Uuid
  locationId    String         @db.Uuid
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  supplier      Supplier       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  location      Location       @relation(fields: [locationId], references: [id], onDelete: Cascade)
  purchaseItems PurchaseItem[]

  @@index([workspaceId])
  @@index([locationId])
  @@index([supplierId])
  @@index([date])
}

model PurchaseItem {
  id         String   @id @default(uuid()) @db.Uuid
  purchaseId String   @db.Uuid
  itemId     String   @db.Uuid
  quantity   Float
  unitCost   Float
  total      Float
  createdAt  DateTime @default(now())
  purchase   Purchase @relation(fields: [purchaseId], references: [id], onDelete: Cascade)
  item       Item     @relation(fields: [itemId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
  @@index([itemId])
}
